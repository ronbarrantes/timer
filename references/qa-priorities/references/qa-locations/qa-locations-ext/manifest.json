{
  "manifest_version": 3,
  "name": "QA Locations MVP",
  "author": "Ron Barrantes <ronbarrantes@gmail.com>",
  "description": "Create a quick locations arrangement table with priorities highlighting.",
  "version": "0.1.0",
  "permissions": ["clipboardWrite"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "QA Locations",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_popup": "popup.html"
  }
}
